---
import Base from '@/layouts/Base.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';

const pricingComparison = [
  { tier: 'Basic / Solo use', postman: 'Free (limited)', scrapeman: 'Free (unlimited)' },
  { tier: 'History / Collections', postman: '25 requests max (free)', scrapeman: 'Unlimited, local' },
  { tier: 'Team collaboration', postman: '$19/user/month', scrapeman: 'Not applicable (local-first)' },
  { tier: 'Cloud sync', postman: 'Required for some features', scrapeman: 'Never — all local' },
  { tier: 'Account required', postman: 'Yes', scrapeman: 'No' },
];

const differences = [
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    title: 'Your data never leaves your machine',
    postman: 'Postman syncs collections to their cloud. Requests, responses, and environments can end up on Postman servers.',
    scrapeman: 'Everything — requests, history, cookies, auth tokens — is stored locally in SQLite. Zero network calls to any third-party.',
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M13 10V3L4 14h7v7l9-11h-7z" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    title: 'Auto-decompression',
    postman: 'Postman does not auto-decompress gzip, brotli, or deflate responses. You see raw compressed bytes unless you manually decode.',
    scrapeman: 'All response encodings decoded automatically. You always see readable content, no config needed.',
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    title: 'SSE streaming',
    postman: 'No native SSE support. You can hit an SSE endpoint but you see the raw stream, not parsed events.',
    scrapeman: 'First-class SSE: events parsed in real time, displayed with id / event / data fields, connection tracked live.',
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4" stroke-linecap="round"/></svg>`,
    title: 'Simpler auth',
    postman: 'OAuth2 authorization code requires callback URL configuration and a built-in browser flow. OAuth2 client credentials are buried in collection-level auth.',
    scrapeman: 'OAuth2 client credentials auto-fetch and cache tokens. Token refreshed before expiry. Concurrent requests share one in-flight token fetch.',
  },
];
---

<Base
  title="Scrapeman vs Postman — Local-First Alternative for Scraping Engineers"
  description="Postman syncs to the cloud and charges $19/user/month. Scrapeman is free, local-first, and auto-decodes gzip/brotli. No account. No subscription cliff. No telemetry."
  ogTitle="Scrapeman vs Postman"
>
  <Header />
  <main>
    <!-- Hero -->
    <section class="hero-bg noise pt-20 pb-24">
      <div class="max-w-4xl mx-auto px-6 text-center">
        <div class="flex items-center justify-center gap-4 mb-10" style="animation: fade-up 0.5s ease-out both;">
          <div class="flex items-center gap-2">
            <div class="w-10 h-10 rounded-xl bg-accent flex items-center justify-center">
              <svg width="20" height="20" viewBox="0 0 16 16" fill="none">
                <circle cx="8" cy="8" r="3" fill="white" opacity="0.9"/>
                <path d="M8 1L8 3M8 13L8 15M1 8L3 8M13 8L15 8M3.05 3.05L4.46 4.46M11.54 11.54L12.95 12.95M12.95 3.05L11.54 4.46M4.46 11.54L3.05 12.95" stroke="white" stroke-width="1.5" stroke-linecap="round" opacity="0.6"/>
              </svg>
            </div>
            <span class="font-bold text-xl text-ink-1">Scrapeman</span>
          </div>
          <span class="text-ink-3 text-2xl font-light">vs</span>
          <div class="flex items-center gap-2">
            <div class="w-10 h-10 rounded-xl bg-orange-400/20 border border-orange-400/30 flex items-center justify-center">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="#ff6c37">
                <path d="M13.527.099C6.955-.744.942 3.9.099 10.473c-.843 6.572 3.8 12.584 10.373 13.428 6.573.843 12.584-3.8 13.428-10.373.843-6.572-3.8-12.584-10.373-13.429zm2.471 7.485a.855.855 0 0 0-.593.25l-4.453 4.453-.307-.307-.643-.643 4.453-4.453a.868.868 0 1 0-1.226-1.226l-4.453 4.453-.937-.937a.868.868 0 1 0-1.226 1.226l.937.937-1.044 1.044a.868.868 0 1 0 1.226 1.226l1.044-1.044.307.307.336.336-1.044 1.044a.868.868 0 1 0 1.226 1.226l1.044-1.044.937.937a.868.868 0 1 0 1.226-1.226l-.937-.937 4.453-4.453a.868.868 0 0 0-.327-1.469z"/>
              </svg>
            </div>
            <span class="font-bold text-xl text-ink-2">Postman</span>
          </div>
        </div>

        <h1 class="text-4xl sm:text-5xl font-bold tracking-tighter text-ink-1 mb-6" style="animation: fade-up 0.5s ease-out 0.1s both;">
          Postman is powerful.<br />
          <span class="gradient-text">You shouldn't need an account to use it.</span>
        </h1>
        <p class="text-lg text-ink-2 max-w-2xl mx-auto leading-relaxed" style="animation: fade-up 0.5s ease-out 0.2s both;">
          Postman built the category. But it evolved into a cloud-first team platform that requires an account, syncs your requests to their servers, and locks history behind a paywall. Scrapeman is the opposite.
        </p>
      </div>
    </section>

    <!-- Pricing comparison -->
    <section class="py-20 border-y border-border bg-bg-surface/30">
      <div class="max-w-3xl mx-auto px-6">
        <div class="text-center mb-12 reveal">
          <p class="section-label mb-3">Pricing</p>
          <h2 class="text-2xl font-bold tracking-tighter text-ink-1">No subscription cliff</h2>
        </div>
        <div class="reveal overflow-hidden rounded-2xl border border-border">
          <table class="w-full text-sm border-collapse">
            <thead>
              <tr class="bg-bg-elevated border-b border-border">
                <th class="text-left px-6 py-4 font-semibold text-ink-2"></th>
                <th class="px-6 py-4 font-semibold text-center text-accent-light">Scrapeman</th>
                <th class="px-6 py-4 font-semibold text-center text-ink-2">Postman</th>
              </tr>
            </thead>
            <tbody>
              {pricingComparison.map((row, i) => (
                <tr class:list={['border-b border-border last:border-0', i % 2 === 0 ? '' : 'bg-bg-surface/30']}>
                  <td class="px-6 py-3.5 text-ink-2 font-medium">{row.tier}</td>
                  <td class="px-6 py-3.5 text-center text-positive text-xs font-semibold">{row.scrapeman}</td>
                  <td class="px-6 py-3.5 text-center text-ink-3 text-xs">{row.postman}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- Key differences -->
    <section class="py-24">
      <div class="max-w-5xl mx-auto px-6">
        <div class="text-center mb-14 reveal">
          <p class="section-label mb-3">Key differences</p>
          <h2 class="text-3xl font-bold tracking-tighter text-ink-1">Built for different goals</h2>
        </div>
        <div class="space-y-8">
          {differences.map((diff) => (
            <div class="reveal grid sm:grid-cols-[auto_1fr_1fr] gap-6 items-start p-6 rounded-2xl border border-border bg-bg-surface">
              <div class="text-accent-light hidden sm:block mt-1">
                <Fragment set:html={diff.icon} />
              </div>
              <div class="sm:col-span-2 grid sm:grid-cols-2 gap-6">
                <div>
                  <div class="flex items-center gap-2 mb-2">
                    <span class="text-xs font-semibold text-negative uppercase tracking-wide">Postman</span>
                  </div>
                  <p class="font-semibold text-ink-1 mb-1">{diff.title}</p>
                  <p class="text-sm text-ink-3 leading-relaxed">{diff.postman}</p>
                </div>
                <div class="sm:border-l sm:border-border sm:pl-6">
                  <div class="flex items-center gap-2 mb-2">
                    <span class="text-xs font-semibold text-positive uppercase tracking-wide">Scrapeman</span>
                  </div>
                  <p class="font-semibold text-ink-1 mb-1">How Scrapeman handles it</p>
                  <p class="text-sm text-ink-3 leading-relaxed">{diff.scrapeman}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section id="download" class="py-24 text-center bg-bg-surface/30">
      <div class="max-w-xl mx-auto px-6 reveal">
        <h2 class="text-3xl font-bold tracking-tighter text-ink-1 mb-4">
          Try it free. Keep it free.
        </h2>
        <p class="text-ink-2 mb-8">
          Scrapeman is free forever. No account. No trial. No surprise billing.
        </p>
        <a href="/#download" class="btn-primary text-base px-10 py-4">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M7 10l5 5 5-5M12 15V3" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Download Scrapeman
        </a>
      </div>
    </section>
  </main>
  <Footer />
</Base>
