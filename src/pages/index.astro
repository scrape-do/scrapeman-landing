---
import Base from '@/layouts/Base.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import Hero from '@/components/home/Hero.astro';
import NumbersBar from '@/components/home/NumbersBar.astro';
import FeatureGrid from '@/components/home/FeatureGrid.astro';
import ComparisonTable from '@/components/home/ComparisonTable.astro';
import TerminalDemo from '@/components/home/TerminalDemo.astro';
import BuiltByAI from '@/components/home/BuiltByAI.astro';
import DownloadCTA from '@/components/home/DownloadCTA.astro';
---

<Base
  title="Scrapeman — Free open source Postman alternative"
  description="An API client with nothing behind a paywall. Unlimited history, env vars, collection runs, and load testing. Git-friendly YAML collections. Native Scrape.do proxy. Apache 2.0, runs offline on macOS, Windows, and Linux."
  jsonLdSoftware={true}
>
  <Header />
  <main>
    <Hero />
    <NumbersBar />
    <FeatureGrid />
    <TerminalDemo />
    <BuiltByAI />
    <ComparisonTable />
    <DownloadCTA />
  </main>
  <Footer />
</Base>
