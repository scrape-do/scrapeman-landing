---
const stats = [
  { value: '0', label: 'accounts required', suffix: '' },
  { value: '100%', label: 'local storage', suffix: '' },
  { value: '2MB+', label: 'response bodies', suffix: '' },
  { value: '5', label: 'auth schemes', suffix: '' },
  { value: '0', label: 'telemetry', suffix: '' },
];
---

<section class="border-y border-border bg-bg-surface/50">
  <div class="max-w-6xl mx-auto px-6 py-12">
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-8 reveal" data-stagger>
      {stats.map(stat => (
        <div class="text-center" data-stagger-child>
          <div class="text-3xl font-bold tracking-tighter text-ink-1 mb-1">
            {stat.value}<span class="text-accent-light">{stat.suffix}</span>
          </div>
          <div class="text-xs text-ink-3 uppercase tracking-widest font-medium">{stat.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>
