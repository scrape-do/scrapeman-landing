---
const stats = [
  { value: '∞', label: 'request history', suffix: '' },
  { value: '∞', label: 'env variables', suffix: '' },
  { value: '∞', label: 'collection runs', suffix: '' },
  { value: '5', label: 'auth schemes', suffix: '' },
  { value: '$0', label: 'forever', suffix: '' },
];
---

<section class="border-y border-[var(--stroke-soft-200)] bg-[var(--bg-weak-50)]" style="background-color: color-mix(in srgb, var(--bg-weak-50) 50%, transparent);">
  <div class="max-w-6xl mx-auto px-6 py-12">
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-8 reveal" data-stagger>
      {stats.map(stat => (
        <div class="text-center" data-stagger-child>
          <div class="text-3xl font-bold tracking-tighter text-[var(--text-strong-950)] mb-1">
            {stat.value}<span class="text-[var(--primary-light)]">{stat.suffix}</span>
          </div>
          <div class="text-xs text-[var(--text-soft-400)] uppercase tracking-widest font-medium">{stat.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>
