---
const rows = [
  { feature: 'Local storage (no cloud)', scrapeman: true, postman: false, bruno: true, insomnia: false },
  { feature: 'No account required', scrapeman: true, postman: false, bruno: true, insomnia: false },
  { feature: 'Auto-decompress gzip/brotli', scrapeman: true, postman: false, bruno: false, insomnia: false },
  { feature: 'Persistent cookie jar', scrapeman: true, postman: true, bruno: false, insomnia: true },
  { feature: 'SSE event streaming', scrapeman: true, postman: false, bruno: false, insomnia: false },
  { feature: '2MB+ body + save to disk', scrapeman: true, postman: false, bruno: false, insomnia: false },
  { feature: 'AWS SigV4 auth', scrapeman: true, postman: true, bruno: true, insomnia: true },
  { feature: 'OAuth2 client credentials', scrapeman: true, postman: true, bruno: true, insomnia: true },
  { feature: 'Auto-set Content-Type', scrapeman: true, postman: true, bruno: false, insomnia: true },
  { feature: 'Free forever', scrapeman: true, postman: false, bruno: true, insomnia: false },
  { feature: 'Open source', scrapeman: true, postman: false, bruno: true, insomnia: false },
];

const Yes = () => '<span class="badge-yes"><svg width="10" height="10" viewBox="0 0 12 12" fill="none"><path d="M2 6l3 3 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>Yes</span>';
const No = () => '<span class="badge-no"><svg width="10" height="10" viewBox="0 0 12 12" fill="none"><path d="M3 3l6 6M9 3l-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>No</span>';
---

<section class="py-28 bg-bg-surface/30">
  <div class="max-w-6xl mx-auto px-6">
    <!-- Section header -->
    <div class="text-center mb-14 reveal">
      <p class="section-label mb-3">Comparison</p>
      <h2 class="text-3xl sm:text-4xl font-bold tracking-tighter text-ink-1 mb-4">
        How Scrapeman stacks up
      </h2>
      <p class="text-ink-2 max-w-lg mx-auto">
        We picked the features that actually matter for scraping workflows.
      </p>
    </div>

    <!-- Table -->
    <div class="reveal overflow-x-auto rounded-2xl border border-border">
      <table class="w-full text-sm border-collapse">
        <thead>
          <tr class="bg-bg-elevated border-b border-border">
            <th class="text-left px-6 py-4 font-semibold text-ink-2 w-1/2">Feature</th>
            <th class="px-6 py-4 font-semibold text-center">
              <span class="inline-flex items-center gap-1.5 text-accent-light">
                <span class="w-5 h-5 rounded bg-accent flex items-center justify-center">
                  <svg width="10" height="10" viewBox="0 0 16 16" fill="none">
                    <circle cx="8" cy="8" r="3" fill="white" opacity="0.9"/>
                    <path d="M8 1L8 3M8 13L8 15M1 8L3 8M13 8L15 8" stroke="white" stroke-width="1.5" stroke-linecap="round" opacity="0.6"/>
                  </svg>
                </span>
                Scrapeman
              </span>
            </th>
            <th class="px-6 py-4 font-semibold text-center text-ink-2">Postman</th>
            <th class="px-6 py-4 font-semibold text-center text-ink-2">Bruno</th>
            <th class="px-6 py-4 font-semibold text-center text-ink-2">Insomnia</th>
          </tr>
        </thead>
        <tbody>
          {rows.map((row, i) => (
            <tr class:list={['border-b border-border last:border-0 transition-colors hover:bg-bg-surface/50', i % 2 === 0 ? 'bg-transparent' : 'bg-bg-surface/20']}>
              <td class="px-6 py-3.5 text-ink-2">{row.feature}</td>
              <td class="px-6 py-3.5 text-center">
                <Fragment set:html={row.scrapeman ? Yes() : No()} />
              </td>
              <td class="px-6 py-3.5 text-center">
                <Fragment set:html={row.postman ? Yes() : No()} />
              </td>
              <td class="px-6 py-3.5 text-center">
                <Fragment set:html={row.bruno ? Yes() : No()} />
              </td>
              <td class="px-6 py-3.5 text-center">
                <Fragment set:html={row.insomnia ? Yes() : No()} />
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <!-- Deep dive links -->
    <div class="flex flex-wrap justify-center gap-4 mt-8 reveal">
      {[
        { label: 'Full breakdown vs Postman', href: '/vs/postman' },
        { label: 'Full breakdown vs Bruno', href: '/vs/bruno' },
        { label: 'Full breakdown vs Insomnia', href: '/vs/insomnia' },
      ].map(link => (
        <a href={link.href} class="inline-flex items-center gap-1.5 text-sm text-accent-light hover:text-ink-1 transition-colors group">
          {link.label}
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="group-hover:translate-x-0.5 transition-transform">
            <path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      ))}
    </div>
  </div>
</section>
