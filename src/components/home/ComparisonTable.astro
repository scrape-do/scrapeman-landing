---
const rows = [
  { feature: 'Unlimited request history', scrapeman: true, postman: false, bruno: true, insomnia: false },
  { feature: 'Unlimited environment variables', scrapeman: true, postman: false, bruno: true, insomnia: true },
  { feature: 'Unlimited collection runs', scrapeman: true, postman: false, bruno: true, insomnia: false },
  { feature: 'Single-request load runner', scrapeman: true, postman: false, bruno: false, insomnia: false },
  { feature: 'Git-friendly file format', scrapeman: true, postman: false, bruno: true, insomnia: false },
  { feature: 'Native Scrape.do proxy mode', scrapeman: true, postman: false, bruno: false, insomnia: false },
  { feature: 'HTTP/2 toggle (undici allowH2)', scrapeman: true, postman: true, bruno: false, insomnia: false },
  { feature: 'OAuth2 all flows', scrapeman: true, postman: false, bruno: true, insomnia: true },
  { feature: 'AWS Signature v4 auth', scrapeman: true, postman: false, bruno: true, insomnia: true },
  { feature: 'Local-first (no cloud sync)', scrapeman: true, postman: false, bruno: true, insomnia: false },
  { feature: 'Free forever', scrapeman: true, postman: false, bruno: true, insomnia: false },
  { feature: 'Open source', scrapeman: true, postman: false, bruno: true, insomnia: false },
];
---

<section class="py-28" style="background-color: color-mix(in srgb, var(--bg-weak-50) 30%, transparent);">
  <div class="max-w-6xl mx-auto px-6">
    <!-- Section header -->
    <div class="text-center mb-14 reveal">
      <p class="section-label mb-3">Comparison</p>
      <h2 class="text-3xl sm:text-4xl font-bold tracking-tighter text-[var(--text-strong-950)] mb-4">
        How Scrapeman stacks up
      </h2>
      <p class="text-[var(--text-sub-600)] max-w-xl mx-auto">
        The Postman column reflects the free tier. Any feature locked behind a paid seat counts as unavailable.
      </p>
    </div>

    <!-- Table -->
    <div class="reveal overflow-x-auto rounded-2xl border border-[var(--stroke-soft-200)]">
      <table class="w-full text-sm border-collapse">
        <thead>
          <tr class="bg-[var(--bg-soft-200)] border-b border-[var(--stroke-soft-200)]">
            <th class="text-left px-6 py-4 font-semibold text-[var(--text-sub-600)] w-1/2">Feature</th>
            <th class="px-6 py-4 font-semibold text-center">
              <span class="inline-flex items-center gap-1.5 text-[var(--primary-light)]">
                <span class="w-5 h-5 rounded bg-[var(--primary-base)] flex items-center justify-center">
                  <svg width="10" height="10" viewBox="0 0 16 16" fill="none">
                    <circle cx="8" cy="8" r="3" fill="white" opacity="0.9"/>
                    <path d="M8 1L8 3M8 13L8 15M1 8L3 8M13 8L15 8" stroke="white" stroke-width="1.5" stroke-linecap="round" opacity="0.6"/>
                  </svg>
                </span>
                Scrapeman
              </span>
            </th>
            <th class="px-6 py-4 font-semibold text-center text-[var(--text-sub-600)]">Postman</th>
            <th class="px-6 py-4 font-semibold text-center text-[var(--text-sub-600)]">Bruno</th>
            <th class="px-6 py-4 font-semibold text-center text-[var(--text-sub-600)]">Insomnia</th>
          </tr>
        </thead>
        <tbody>
          {rows.map((row, i) => (
            <tr class:list={['border-b border-[var(--stroke-soft-200)] last:border-0 transition-colors hover:bg-[var(--bg-weak-50)]', i % 2 !== 0 && 'bg-[var(--bg-white-0)]']}>
              <td class="px-6 py-3.5 text-[var(--text-sub-600)]">{row.feature}</td>
              <td class="px-6 py-3.5 text-center">
                {row.scrapeman
                  ? <span class="inline-flex items-center gap-1 rounded-full px-2.5 py-0.5 text-xs font-semibold bg-[var(--success-alpha-10)] text-[var(--success-base)]">Yes</span>
                  : <span class="inline-flex items-center gap-1 rounded-full px-2.5 py-0.5 text-xs font-semibold bg-[var(--error-alpha-10)] text-[var(--error-base)]">No</span>
                }
              </td>
              <td class="px-6 py-3.5 text-center">
                {row.postman
                  ? <span class="inline-flex items-center gap-1 rounded-full px-2.5 py-0.5 text-xs font-semibold bg-[var(--success-alpha-10)] text-[var(--success-base)]">Yes</span>
                  : <span class="inline-flex items-center gap-1 rounded-full px-2.5 py-0.5 text-xs font-semibold bg-[var(--error-alpha-10)] text-[var(--error-base)]">No</span>
                }
              </td>
              <td class="px-6 py-3.5 text-center">
                {row.bruno
                  ? <span class="inline-flex items-center gap-1 rounded-full px-2.5 py-0.5 text-xs font-semibold bg-[var(--success-alpha-10)] text-[var(--success-base)]">Yes</span>
                  : <span class="inline-flex items-center gap-1 rounded-full px-2.5 py-0.5 text-xs font-semibold bg-[var(--error-alpha-10)] text-[var(--error-base)]">No</span>
                }
              </td>
              <td class="px-6 py-3.5 text-center">
                {row.insomnia
                  ? <span class="inline-flex items-center gap-1 rounded-full px-2.5 py-0.5 text-xs font-semibold bg-[var(--success-alpha-10)] text-[var(--success-base)]">Yes</span>
                  : <span class="inline-flex items-center gap-1 rounded-full px-2.5 py-0.5 text-xs font-semibold bg-[var(--error-alpha-10)] text-[var(--error-base)]">No</span>
                }
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <!-- Deep dive links -->
    <div class="flex flex-wrap justify-center gap-4 mt-8 reveal">
      {[
        { label: 'Full breakdown vs Postman', href: '/postman-alternative' },
        { label: 'Full breakdown vs Bruno', href: '/bruno-alternative' },
        { label: 'Full breakdown vs Insomnia', href: '/insomnia-alternative' },
        { label: 'Full breakdown vs Hoppscotch', href: '/hoppscotch-alternative' },
        { label: 'Full breakdown vs Yaak', href: '/yaak-alternative' },
      ].map(link => (
        <a href={link.href} class="inline-flex items-center gap-1.5 text-sm text-[var(--primary-light)] hover:text-[var(--text-strong-950)] transition-colors group">
          {link.label}
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="group-hover:translate-x-0.5 transition-transform">
            <path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      ))}
    </div>
  </div>
</section>
