---
---

<section class="hero-bg noise relative overflow-hidden pt-16 pb-32">
  <!-- Background glow orbs -->
  <div class="pointer-events-none absolute inset-0 overflow-hidden">
    <div class="absolute -top-40 left-1/2 -translate-x-1/2 w-[800px] h-[500px] rounded-full bg-accent/8 blur-[120px]"></div>
    <div class="absolute top-60 right-0 w-[400px] h-[400px] rounded-full bg-accent-violet/6 blur-[100px]"></div>
  </div>

  <div class="relative max-w-6xl mx-auto px-6">
    <!-- Badge -->
    <div class="flex justify-center mb-8 animate-fade-in">
      <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-accent/30 bg-accent/8 text-xs font-semibold text-accent-light tracking-wide">
        <span class="w-1.5 h-1.5 rounded-full bg-positive animate-pulse-green"></span>
        Built for scraping engineers
      </span>
    </div>

    <!-- Headline -->
    <h1 class="text-center font-bold tracking-tighter leading-[1.05] mb-6" style="animation: fade-up 0.6s ease-out 0.1s both;">
      <span class="block text-5xl sm:text-6xl lg:text-7xl text-ink-1 mb-2">The HTTP client that</span>
      <span class="block text-5xl sm:text-6xl lg:text-7xl gradient-text">doesn't slow you down.</span>
    </h1>

    <!-- Subheadline -->
    <p class="text-center text-lg sm:text-xl text-ink-2 max-w-2xl mx-auto leading-relaxed mb-10" style="animation: fade-up 0.6s ease-out 0.2s both;">
      Send requests, inspect responses, replay scraping sessions.
      <br class="hidden sm:block" />
      No account. No cloud. No subscription. Local-first. Always yours.
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-20" style="animation: fade-up 0.6s ease-out 0.3s both;">
      <a href="#download" class="btn-primary text-base px-8 py-3.5">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M7 10l5 5 5-5M12 15V3"/>
        </svg>
        Download for Mac
      </a>
      <a
        href="https://github.com/scrapeman"
        target="_blank"
        rel="noopener"
        class="btn-ghost text-base px-8 py-3.5"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
        </svg>
        View on GitHub
      </a>
    </div>

    <!-- App mockup -->
    <div class="relative flex justify-center" style="animation: fade-up 0.8s ease-out 0.4s both;">
      <!-- Glow behind mockup -->
      <div class="absolute inset-0 -top-8 rounded-3xl bg-accent/10 blur-3xl scale-90"></div>

      <!-- The mockup frame -->
      <div
        data-parallax
        class="relative w-full max-w-4xl rounded-2xl border border-border-strong bg-bg-surface overflow-hidden shadow-2xl"
        style="box-shadow: 0 0 0 1px #1e1e2e, 0 40px 80px rgba(0,0,0,0.6), 0 0 60px rgba(99,102,241,0.08);"
      >
        <!-- Traffic light bar -->
        <div class="flex items-center gap-2 px-4 py-3 border-b border-border bg-bg-elevated">
          <div class="w-3 h-3 rounded-full bg-negative/70"></div>
          <div class="w-3 h-3 rounded-full bg-yellow-500/70"></div>
          <div class="w-3 h-3 rounded-full bg-positive/70"></div>
          <div class="flex-1 flex justify-center">
            <div class="flex items-center gap-2 px-3 py-1 rounded-md bg-bg text-xs text-ink-3 font-mono">
              <span class="text-positive text-xs">●</span>
              GET
              <span class="text-accent-light">https://api.scrape.do/v1/scrape</span>
            </div>
          </div>
          <div class="w-16"></div>
        </div>

        <!-- App body -->
        <div class="grid grid-cols-[260px_1fr] min-h-[420px] text-xs font-mono">
          <!-- Left sidebar -->
          <div class="border-r border-border bg-bg-elevated p-3 space-y-0.5">
            <div class="px-2 py-1 text-ink-3 text-[10px] font-sans font-semibold tracking-widest uppercase mb-2">Requests</div>
            <div class="flex items-center gap-2 px-2 py-1.5 rounded-md bg-accent/15 border border-accent/25">
              <span class="text-positive font-semibold text-[10px]">GET</span>
              <span class="text-ink-1 truncate">Scrape Target</span>
            </div>
            <div class="flex items-center gap-2 px-2 py-1.5 rounded-md hover:bg-bg-surface">
              <span class="text-blue-400 font-semibold text-[10px]">POST</span>
              <span class="text-ink-2 truncate">Auth Token</span>
            </div>
            <div class="flex items-center gap-2 px-2 py-1.5 rounded-md hover:bg-bg-surface">
              <span class="text-positive font-semibold text-[10px]">GET</span>
              <span class="text-ink-2 truncate">Product List</span>
            </div>
            <div class="flex items-center gap-2 px-2 py-1.5 rounded-md hover:bg-bg-surface">
              <span class="text-positive font-semibold text-[10px]">GET</span>
              <span class="text-ink-2 truncate">Price History</span>
            </div>
          </div>

          <!-- Main panel -->
          <div class="flex flex-col">
            <!-- Response tabs -->
            <div class="flex items-center gap-0 border-b border-border px-4 pt-2">
              {['Body', 'Headers', 'Cookies', 'Timeline'].map((tab, i) => (
                <button class:list={[
                  'px-4 py-2 text-xs font-sans font-medium border-b-2 -mb-px transition-colors',
                  i === 0
                    ? 'border-accent text-ink-1'
                    : 'border-transparent text-ink-3 hover:text-ink-2'
                ]}>
                  {tab}
                </button>
              ))}
              <div class="ml-auto flex items-center gap-2 pb-2">
                <span class="px-2 py-0.5 rounded-md bg-positive/15 text-positive text-[10px] font-sans font-semibold">200 OK</span>
                <span class="text-ink-3 text-[10px] font-sans">142ms · 8.4 KB</span>
              </div>
            </div>

            <!-- Response body -->
            <div class="flex-1 p-4 overflow-auto">
              <pre class="text-[11px] leading-relaxed"><code><span class="text-border-strong">{'{'}</span>
  <span class="text-accent-light">"status"</span><span class="text-ink-3">:</span> <span class="text-positive">"success"</span><span class="text-ink-3">,</span>
  <span class="text-accent-light">"url"</span><span class="text-ink-3">:</span> <span class="text-positive">"https://shop.example.com/products"</span><span class="text-ink-3">,</span>
  <span class="text-accent-light">"content"</span><span class="text-ink-3">:</span> <span class="text-positive">"&lt;!DOCTYPE html&gt;..."</span><span class="text-ink-3">,</span>
  <span class="text-accent-light">"resolvedUrl"</span><span class="text-ink-3">:</span> <span class="text-positive">"https://shop.example.com/products?page=1"</span><span class="text-ink-3">,</span>
  <span class="text-accent-light">"cookies"</span><span class="text-ink-3">:</span> <span class="text-border-strong">{'['}</span>
    <span class="text-border-strong">{'{'}</span> <span class="text-accent-light">"name"</span><span class="text-ink-3">:</span> <span class="text-positive">"session_id"</span><span class="text-ink-3">,</span> <span class="text-accent-light">"value"</span><span class="text-ink-3">:</span> <span class="text-positive">"abc123"</span> <span class="text-border-strong">{'}'}</span>
  <span class="text-border-strong">{']'}</span>
<span class="text-border-strong">{'}'}</span></code></pre>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Trust signals -->
    <div class="flex flex-wrap justify-center gap-6 mt-12 text-xs text-ink-3" style="animation: fade-in 0.6s ease-out 0.8s both;">
      {[
        'No account required',
        'No telemetry',
        'Stores data locally',
        'Free & open source',
      ].map(label => (
        <span class="flex items-center gap-1.5">
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
            <path d="M2 6l3 3 5-5" stroke="#22c55e" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          {label}
        </span>
      ))}
    </div>
  </div>
</section>
