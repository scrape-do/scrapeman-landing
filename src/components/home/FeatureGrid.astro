---
const features = [
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M13 10V3L4 14h7v7l9-11h-7z" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    title: 'Gzip · Brotli · Deflate',
    desc: 'Response bodies are automatically decompressed. No manual Accept-Encoding juggling — just readable content, always.',
    tag: 'Zero config',
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    title: 'SSE Streaming',
    desc: 'Watch Server-Sent Events arrive in real time. Full event log with data, id, and event type — perfect for debugging AI APIs.',
    tag: 'Real-time',
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="3"/><path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/></svg>`,
    title: 'Persistent Cookie Jar',
    desc: 'Cookies survive restarts. Your scraping session state is saved to disk automatically — no re-login on every run.',
    tag: 'Persists restarts',
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 9h6M9 12h6M9 15h4" stroke-linecap="round"/></svg>`,
    title: 'Auto-Headers Engine',
    desc: 'Content-Type, Accept, and User-Agent are set automatically based on request type. Override or disable per-request.',
    tag: 'Postman parity',
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M7 10l5 5 5-5M12 15V3" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    title: 'Large Response Handling',
    desc: '2MB+ response bodies are captured and can be saved directly to disk. No more browser tab crashes on big payloads.',
    tag: '2MB+ bodies',
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4" stroke-linecap="round"/></svg>`,
    title: 'Every Auth Scheme',
    desc: 'Basic, Bearer, API Key, OAuth2 client credentials, and AWS SigV4. Tokens are cached and auto-refreshed before expiry.',
    tag: '5 schemes',
  },
];
---

<section class="py-28">
  <div class="max-w-6xl mx-auto px-6">
    <!-- Section header -->
    <div class="text-center mb-16 reveal">
      <p class="section-label mb-3">Features</p>
      <h2 class="text-3xl sm:text-4xl font-bold tracking-tighter text-ink-1 mb-4">
        Everything a scraping engineer needs.<br />
        <span class="gradient-text">Nothing you don't.</span>
      </h2>
      <p class="text-ink-2 max-w-xl mx-auto">
        Built from real pain points. Every feature exists because a scraping engineer hit a wall with every other client.
      </p>
    </div>

    <!-- Feature grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 reveal" data-stagger>
      {features.map(f => (
        <div class="glow-card group" data-stagger-child>
          <!-- Icon -->
          <div class="w-10 h-10 rounded-xl bg-accent/10 border border-accent/20 flex items-center justify-center text-accent-light mb-4 group-hover:bg-accent/15 transition-colors">
            <Fragment set:html={f.icon} />
          </div>
          <!-- Tag -->
          <span class="inline-block px-2 py-0.5 rounded-md bg-bg text-[10px] font-semibold text-ink-3 uppercase tracking-widest border border-border mb-3">
            {f.tag}
          </span>
          <h3 class="font-semibold text-ink-1 mb-2">{f.title}</h3>
          <p class="text-sm text-ink-3 leading-relaxed">{f.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
