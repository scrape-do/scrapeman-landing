---
---

<section class="py-28">
  <div class="max-w-6xl mx-auto px-6">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <!-- Left: text -->
      <div class="reveal-left">
        <p class="section-label mb-3">How it works</p>
        <h2 class="text-3xl sm:text-4xl font-bold tracking-tighter text-[var(--text-strong-950)] mb-6">
          Build, send,<br />
          <span class="gradient-text">and load-test.</span>
        </h2>
        <div class="space-y-5 text-[var(--text-sub-600)]">
          <div class="flex gap-3">
            <div class="flex-shrink-0 w-6 h-6 rounded-full bg-[var(--primary-alpha-10)] border border-[var(--stroke-soft-200)] flex items-center justify-center mt-0.5">
              <span class="text-[var(--primary-light)] text-xs font-bold">1</span>
            </div>
            <div>
              <p class="font-semibold text-[var(--text-strong-950)] mb-1">Build the request</p>
              <p class="text-sm text-[var(--text-soft-400)] leading-relaxed">URL bar with <code class="font-mono text-[var(--primary-light)]">{'{{var}}'}</code> autocomplete. Environment vars resolve across URL, headers, body, auth, and proxy. Params tab stays two-way synced with the query string.</p>
            </div>
          </div>
          <div class="flex gap-3">
            <div class="flex-shrink-0 w-6 h-6 rounded-full bg-[var(--primary-alpha-10)] border border-[var(--stroke-soft-200)] flex items-center justify-center mt-0.5">
              <span class="text-[var(--primary-light)] text-xs font-bold">2</span>
            </div>
            <div>
              <p class="font-semibold text-[var(--text-strong-950)] mb-1">Send with any config</p>
              <p class="text-sm text-[var(--text-soft-400)] leading-relaxed">Any auth scheme, any HTTP version, any proxy. Per-request timeouts and redirect rules. Flip the scrape.do toggle when you need residential rotation or JS rendering.</p>
            </div>
          </div>
          <div class="flex gap-3">
            <div class="flex-shrink-0 w-6 h-6 rounded-full bg-[var(--primary-alpha-10)] border border-[var(--stroke-soft-200)] flex items-center justify-center mt-0.5">
              <span class="text-[var(--primary-light)] text-xs font-bold">3</span>
            </div>
            <div>
              <p class="font-semibold text-[var(--text-strong-950)] mb-1">Replay, diff, or load-test</p>
              <p class="text-sm text-[var(--text-soft-400)] leading-relaxed">Every send writes to local JSONL history, template-preserving so <code class="font-mono text-[var(--primary-light)]">{'{{token}}'}</code> stays <code class="font-mono text-[var(--primary-light)]">{'{{token}}'}</code> on disk. Restore in one click, or run 1000 iterations through the load runner with a response validator.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Right: fake terminal -->
      <div class="reveal-right">
        <div class="rounded-2xl border border-[var(--stroke-soft-200)] bg-[var(--bg-soft-200)] overflow-hidden shadow-2xl">
          <!-- Terminal bar -->
          <div class="flex items-center gap-2 px-4 py-3 border-b border-[var(--stroke-soft-200)] bg-[var(--bg-white-0)]">
            <div class="w-3 h-3 rounded-full bg-[var(--error-base)] opacity-70"></div>
            <div class="w-3 h-3 rounded-full bg-yellow-500 opacity-70"></div>
            <div class="w-3 h-3 rounded-full bg-[var(--success-base)] opacity-70"></div>
            <span class="ml-2 text-xs text-[var(--text-soft-400)] font-mono">response · 200 OK · 142ms</span>
          </div>

          <!-- Terminal content -->
          <div class="p-5 font-mono text-xs leading-6 space-y-1" id="terminal-demo">
            <div class="text-[var(--text-soft-400)]"># Request</div>
            <div><span class="text-[var(--primary-light)]">GET</span> <span class="text-[var(--text-sub-600)]">https://api.scrape.do/v1/scrape?url=...</span></div>
            <div class="text-[var(--text-soft-400)] mt-2"># Auto-headers (Scrapeman managed)</div>
            <div><span class="text-[var(--success-base)]">Accept-Encoding</span><span class="text-[var(--text-soft-400)]">: </span><span class="text-[var(--text-sub-600)]">gzip, br, deflate</span></div>
            <div><span class="text-[var(--success-base)]">Content-Type</span><span class="text-[var(--text-soft-400)]">: </span><span class="text-[var(--text-sub-600)]">application/json</span></div>
            <div><span class="text-[var(--success-base)]">Authorization</span><span class="text-[var(--text-soft-400)]">: </span><span class="text-[var(--text-sub-600)]">Bearer ey••••••••</span></div>
            <div class="mt-2 text-[var(--text-soft-400)]"># Response (auto-decompressed)</div>
            <div class="text-[var(--success-base)]">✓ 200 OK · gzip → decoded · 8.4 KB</div>
            <div class="mt-2 text-[var(--text-soft-400)]"># Cookies saved</div>
            <div><span class="text-[var(--primary-light)]">session_id</span><span class="text-[var(--text-soft-400)]"> = </span><span class="text-[var(--text-sub-600)]">abc123f4 (persisted)</span></div>
            <div><span class="text-[var(--primary-light)]">cf_clearance</span><span class="text-[var(--text-soft-400)]"> = </span><span class="text-[var(--text-sub-600)]">x9k2m••• (persisted)</span></div>
            <div class="mt-2 flex items-center gap-1">
              <span class="text-[var(--success-base)]">▶</span>
              <span class="text-[var(--text-strong-950)]">Ready</span>
              <span class="inline-block w-2 h-4 bg-[var(--text-strong-950)] animate-blink ml-0.5"></span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
