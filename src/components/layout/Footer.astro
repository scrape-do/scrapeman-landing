---
const year = new Date().getFullYear();
---

<footer class="border-t border-[var(--stroke-soft-200)] mt-32">
  <div class="max-w-6xl mx-auto px-6 py-16">
    <div class="flex flex-col md:flex-row justify-between gap-12">
      <!-- Brand -->
      <div class="max-w-xs">
        <a href="/" class="flex items-center gap-2.5 mb-4">
          <svg width="32" height="22" viewBox="4 14 56 40" role="img" aria-label="Scrapeman" class="shrink-0">
            <path d="M8 20 L40 20 Q52 20 52 34 Q52 46 40 46 Q30 46 30 36 L36 40" fill="none" stroke="#ff6c37" stroke-width="6" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span class="font-bold text-[var(--text-strong-950)] tracking-tight text-[17px] leading-none">Scrapeman</span>
        </a>
        <p class="text-sm text-[var(--text-soft-400)] leading-relaxed">
          The unlimited API client. Every Postman paid feature shipped free, plus native scrape-do proxy and git-friendly YAML collections. Apache 2.0 on GitHub.
        </p>
      </div>

      <!-- Links -->
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-8 text-sm">
        <div>
          <p class="font-semibold text-[var(--text-strong-950)] mb-3">Compare</p>
          <ul class="space-y-2 text-[var(--text-soft-400)]">
            <li><a href="/vs/postman" class="hover:text-[var(--text-strong-950)] transition-colors">vs Postman</a></li>
            <li><a href="/vs/bruno" class="hover:text-[var(--text-strong-950)] transition-colors">vs Bruno</a></li>
            <li><a href="/vs/insomnia" class="hover:text-[var(--text-strong-950)] transition-colors">vs Insomnia</a></li>
          </ul>
        </div>
        <div>
          <p class="font-semibold text-[var(--text-strong-950)] mb-3">Product</p>
          <ul class="space-y-2 text-[var(--text-soft-400)]">
            <li><a href="/features" class="hover:text-[var(--text-strong-950)] transition-colors">Features</a></li>
            <li><a href="#download" class="hover:text-[var(--text-strong-950)] transition-colors">Download</a></li>
          </ul>
        </div>
        <div>
          <p class="font-semibold text-[var(--text-strong-950)] mb-3">Open Source</p>
          <ul class="space-y-2 text-[var(--text-soft-400)]">
            <li>
              <a href="https://github.com/scrape-do/scrapeman" target="_blank" rel="noopener" class="hover:text-[var(--text-strong-950)] transition-colors">
                GitHub
              </a>
            </li>
            <li>
              <a href="https://github.com/scrape-do/scrapeman/releases" target="_blank" rel="noopener" class="hover:text-[var(--text-strong-950)] transition-colors">
                Releases
              </a>
            </li>
            <li>
              <a href="https://github.com/scrape-do/scrapeman/blob/main/LICENSE" target="_blank" rel="noopener" class="hover:text-[var(--text-strong-950)] transition-colors">
                Apache 2.0 license
              </a>
            </li>
          </ul>
        </div>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-[var(--stroke-soft-200)] flex flex-col sm:flex-row justify-between items-center gap-4 text-xs text-[var(--text-soft-400)]">
      <p>© {year} scrape-do. Apache 2.0. No tracking, no telemetry, no account.</p>
      <p>Made by <a href="https://scrape.do/?utm_source=scrapeman&utm_medium=landing&utm_campaign=footer" target="_blank" rel="noopener" class="text-[var(--primary-light)] hover:underline">scrape.do</a>, the scraping infrastructure of the internet.</p>
    </div>
  </div>
</footer>
