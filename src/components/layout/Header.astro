---
import { Button } from '@/components/ui/Button';

const navLinks = [
  { label: 'vs Postman', href: '/postman-alternative' },
  { label: 'vs Bruno', href: '/bruno-alternative' },
  { label: 'vs Insomnia', href: '/insomnia-alternative' },
  { label: 'vs Hoppscotch', href: '/hoppscotch-alternative' },
  { label: 'vs Yaak', href: '/yaak-alternative' },
  { label: 'Features', href: '/features' },
  { label: 'Docs', href: '/docs' },
];

const currentPath = Astro.url.pathname;
---

<header class="fixed top-0 left-0 right-0 z-50 border-b border-[var(--stroke-soft-200)]/50 bg-[var(--bg-white-0)]/80 backdrop-blur-xl">
  <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
    <!-- Logo (real scrape-do orange mark) -->
    <a href="/" class="flex items-center gap-2.5 group">
      <svg width="32" height="22" viewBox="4 14 56 40" role="img" aria-label="Scrapeman" class="transition-transform group-hover:-rotate-6 shrink-0">
        <path d="M8 20 L40 20 Q52 20 52 34 Q52 46 40 46 Q30 46 30 36 L36 40" fill="none" stroke="#ff6c37" stroke-width="6" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <span class="font-bold text-[var(--text-strong-950)] tracking-tight text-[17px] leading-none">Scrapeman</span>
    </a>

    <!-- Nav -->
    <nav class="hidden md:flex items-center gap-1">
      {navLinks.map(link => (
        <a
          href={link.href}
          class:list={[
            'px-4 py-2 rounded-lg text-sm font-medium transition-colors',
            currentPath === link.href
              ? 'text-[var(--text-strong-950)] bg-[var(--bg-soft-200)]'
              : 'text-[var(--text-sub-600)] hover:text-[var(--text-strong-950)] hover:bg-[var(--bg-soft-200)]/60'
          ]}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <!-- CTA -->
    <div class="flex items-center gap-3">
      <!-- GitHub link as ghost-styled anchor -->
      <a
        href="https://github.com/scrape-do/scrapeman"
        class="hidden sm:flex items-center gap-1.5 text-sm text-[var(--text-sub-600)] hover:text-[var(--text-strong-950)] transition-colors"
        target="_blank"
        rel="noopener"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
        </svg>
        GitHub
      </a>

      <!-- Download CTA rendered as Button component wrapping an anchor -->
      <Button asChild variant="primary" size="sm">
        <a href="#download" class="inline-flex items-center gap-2">
          Download
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M7 10l5 5 5-5M12 15V3"/>
          </svg>
        </a>
      </Button>
    </div>
  </div>
</header>

<!-- Spacer for fixed header -->
<div class="h-16"></div>
